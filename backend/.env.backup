# ============================================
# ACCOUNTANTOS v9.7 - Variables de Entorno
# ============================================
# Desarrollo Local - Docker
# ============================================

# ---------------------------------------------
# CONFIGURACIÓN GENERAL
# ---------------------------------------------
ENVIRONMENT=development
SECRET_KEY=dev_secret_key_for_local_development_only_2024
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ---------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=accountantos
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------
# REDIS (Caché y Cola de Tareas)
# ---------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PERSISTENCE=no

# ---------------------------------------------
# ARCA/AFIP - Certificados y Configuración
# ---------------------------------------------
ARCA_CERT_PATH=/app/certs/certificado.cer
ARCA_KEY_PATH=/app/certs/clave_privada.key
ARCA_CA_PATH=/app/certs/ca_afip.crt
ARCA_CUIT_ESTUDIO=20123456789
ARCA_CERT_PASSWORD=
ARCA_AMBIENTE=hom

# ---------------------------------------------
# GOOGLE CLOUD / GEMINI (OCR)
# ---------------------------------------------
GOOGLE_CLOUD_PROJECT=dev-project
GOOGLE_CLOUD_KEY_PATH=/app/gcp/service-account-key.json
GEMINI_MODEL=gemini-1.5-pro
GEMINI_LOCATION=us-central1

# ---------------------------------------------
# SEGURIDAD - KMS y HMAC
# ---------------------------------------------
KMS_PROVIDER=gcp
KMS_KEY_ID=projects/dev-project/locations/global/keyRings/accountantos/cryptoKeys/master
VAULT_URL=https://vault.local
VAULT_ROLE_ID=
VAULT_SECRET_ID=
HMAC_SALT_MASTER=dev_salt_for_hmac_local_testing_minimum_32_chars

# ---------------------------------------------
# JWT y AUTENTICACIÓN
# ---------------------------------------------
JWT_SECRET_KEY=dev_jwt_secret_key_for_local_testing_2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------
# CELERY (Workers Asíncronos)
# ---------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4

# ---------------------------------------------
# LOGGING Y MONITOREO
# ---------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=json
PROMETHEUS_PORT=9090

# ---------------------------------------------
# RATE LIMITING
# ---------------------------------------------
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_REDIS_DB=2

# ---------------------------------------------
# CONFIGURACIÓN DE VEPs
# ---------------------------------------------
VEP_FRICTION_THRESHOLD=50000
VEP_PRE_GENERACION_DIAS=7

# ---------------------------------------------
# NOTIFICACIONES (WhatsApp Business API)
# ---------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
