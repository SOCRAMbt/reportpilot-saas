# ============================================
# ACCOUNTANTOS v9.7 - Variables de Entorno
# ============================================
# Copiar este archivo a .env y completar los valores
# ============================================

# ---------------------------------------------
# CONFIGURACIÓN GENERAL
# ---------------------------------------------
ENVIRONMENT=development
SECRET_KEY=tu_secret_key_muy_largo_y_seguro_cambiar_en_produccion
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ---------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=accountantos
DATABASE_USER=accountantos
DATABASE_PASSWORD=tu_password_seguro
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------
# REDIS (Caché y Cola de Tareas)
# ---------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# IMPORTANTE: En producción, Redis NO debe tener persistencia para tokens WSAA
REDIS_PERSISTENCE=no

# ---------------------------------------------
# ARCA/AFIP - Certificados y Configuración
# ---------------------------------------------
# Rutas a los archivos .pem
ARCA_CERT_PATH=/path/to/certificado.cer
ARCA_KEY_PATH=/path/to/clave_privada.key
ARCA_CA_PATH=/path/to/ca_afip.crt

# CUIT del estudio contable (sin guiones)
ARCA_CUIT_ESTUDIO=20123456789

# Contraseña del certificado (si tiene)
ARCA_CERT_PASSWORD=

# Ambiente: hom (homologación) o pro (producción)
ARCA_AMBIENTE=hom

# ---------------------------------------------
# DELEGACIÓN ARCA - Administrador de Relaciones
# ---------------------------------------------
# Los clientes deben delegar acceso desde su cuenta de ARCA
# al CUIT del estudio usando el Administrador de Relaciones
# Ver docs/CONFIGURACION_ARCA.md para instrucciones

# ---------------------------------------------
# GOOGLE CLOUD / GEMINI (OCR)
# ---------------------------------------------
GOOGLE_CLOUD_PROJECT=tu_proyecto_gcp
GOOGLE_CLOUD_KEY_PATH=/path/to/service-account-key.json
# Vertex AI endpoint (Enterprise con ZDR)
GEMINI_MODEL=gemini-1.5-pro
GEMINI_LOCATION=us-central1
# IMPORTANTE: Usar Vertex AI, NO la API pública

# ---------------------------------------------
# SEGURIDAD - KMS y HMAC
# ---------------------------------------------
# KMS para gestión de claves (AWS KMS, GCP KMS, o HashiCorp Vault)
KMS_PROVIDER=gcp  # aws, gcp, vault
KMS_KEY_ID=projects/tu-proyecto/locations/global/keyRings/accountantos/cryptoKeys/master
# Para on-premise con Vault:
VAULT_URL=https://vault.tuempresa.com
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# Salt para HMAC-SHA256 de CUITs (se guarda en KMS, esto es solo para bootstrap)
HMAC_SALT_MASTER=cambiar_esto_por_valor_seguro_desde_kms

# ---------------------------------------------
# JWT y AUTENTICACIÓN
# ---------------------------------------------
JWT_SECRET_KEY=otro_secret_muy_seguro_para_jwt
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------
# CELERY (Workers Asíncronos)
# ---------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4

# ---------------------------------------------
# LOGGING Y MONITOREO
# ---------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_PORT=9090

# ---------------------------------------------
# RATE LIMITING
# ---------------------------------------------
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_REDIS_DB=2

# ---------------------------------------------
# CONFIGURACIÓN DE VEPs
# ---------------------------------------------
# Friction cognitiva: monto mínimo para requerir escritura manual
VEP_FRICTION_THRESHOLD=50000
# Días para pre-generar borradores
VEP_PRE_GENERACION_DIAS=7

# ---------------------------------------------
# NOTIFICACIONES (WhatsApp Business API)
# ---------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
